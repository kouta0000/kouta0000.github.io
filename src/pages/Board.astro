---
// src/components/Board.astro
import { db, BoardPost, desc } from "astro:db";
import Layout from "@/layouts/Layout.astro"

const posts = await db
  .select()
  .from(BoardPost)
  .orderBy(desc(BoardPost.postedAt))
  .limit(50);

function fmtDate(d: Date | string | null): string {
  if (!d) return "";
  const dt = d instanceof Date ? d : new Date(d);
  if (isNaN(dt.getTime())) return String(d);
  return dt.toLocaleString("ja-JP", {
    month:  "numeric",
    day:    "numeric",
    hour:   "2-digit",
    minute: "2-digit",
  });
}

// Classes répétées pour la maintenance (arbitrary values pour coller à vos hex précis)
const styles = {
  post: "py-[0.6rem] border-b border-[#e0e0e0] dark:border-[#2a2a2a] first:border-t",
  meta: "flex gap-[0.55rem] items-baseline mb-[0.15rem]",
  name: "text-[0.7rem] font-medium",
  time: "text-[0.64rem] text-[#999] dark:text-[#666]",
  body: "text-[0.76rem] leading-[1.65] whitespace-pre-wrap break-words",
  input: "font-inherit text-[0.76rem] bg-[#f7f7f7] dark:bg-[#1a1a1a] text-[#111] dark:text-[#e4e4e4] border-[0.5px] border-[#e0e0e0] dark:border-[#2a2a2a] px-[0.55rem] py-[0.42rem] outline-none transition-colors focus:border-[#111] dark:focus:border-[#e4e4e4] w-full rounded-none"
};
---

<Layout>
<section class="font-mono text-[#111] dark:text-[#e4e4e4]">
  <h2 class="font-serif text-[1.3rem] font-normal border-b border-[#111] dark:border-[#e4e4e4] pb-[0.35rem] mb-[1.1rem]">
    掲示板
  </h2>

  <ol class="list-none p-0 m-0 mb-[1.4rem]" id="post-list">
    {posts.length === 0 && (
      <li class="post-empty text-[0.74rem] text-[#999] dark:text-[#666] py-[0.4rem]">
        まだ投稿がありません。
      </li>
    )}
    {posts.map((p) => (
      <li class={styles.post}>
        <div class={styles.meta}>
          <span class={styles.name}>{p.name}</span>
          <time class={styles.time} datetime={String(p.postedAt)}>
            {fmtDate(p.postedAt)}
          </time>
        </div>
        <p class={styles.body}>{p.body}</p>
      </li>
    ))}
  </ol>

  <form class="flex flex-col gap-[0.4rem]" id="board-form" novalidate>
    <input
      id="inp-name"
      class={styles.input}
      type="text"
      placeholder="名前（任意）"
      maxlength="50"
    />
    <input
      id="inp-body"
      class={styles.input}
      type="text"
      placeholder="メッセージ（必須）"
      maxlength="400"
      required
    />
    <div class="flex justify-between items-center">
      <span class="text-[0.62rem] text-[#999] dark:text-[#666]">
        <span id="char-count">0</span> / 400
      </span>
      <button 
        type="submit" 
        id="board-btn" 
        class="font-inherit text-[0.7rem] bg-[#111] dark:bg-[#e4e4e4] text-[#f7f7f7] dark:text-[#1a1a1a] px-[0.85rem] py-[0.38rem] cursor-pointer tracking-wider transition-opacity hover:opacity-70 active:opacity-50 disabled:opacity-40 disabled:cursor-not-allowed"
      >
        投稿
      </button>
    </div>
    <p id="form-error" class="text-[0.65rem] text-[#b33] min-h-[1em] m-0" aria-live="polite"></p>
  </form>
</section>
</Layout>

<script define:vars={{ styles }}>
  // On passe les classes Tailwind au script pour que l'injection JS soit identique au SSR
  (() => {
    const form    = document.getElementById("board-form");
    const nameEl  = document.getElementById("inp-name");
    const bodyEl  = document.getElementById("inp-body");
    const btn     = document.getElementById("board-btn");
    const errEl   = document.getElementById("form-error");
    const listEl  = document.getElementById("post-list");
    const countEl = document.getElementById("char-count");

    bodyEl.addEventListener("input", () => {
      countEl.textContent = String(bodyEl.value.length);
    });

    function prependPost(name, body, postedAt) {
      listEl.querySelector(".post-empty")?.remove();

      const li = document.createElement("li");
      li.className = styles.post; // Application de la classe Tailwind via l'objet styles
      li.innerHTML =
        `<div class="${styles.meta}">` +
          `<span class="${styles.name}">${esc(name)}</span>` +
          `<time class="${styles.time}">${esc(postedAt)}</time>` +
        `</div>` +
        `<p class="${styles.body}">${esc(body)}</p>`;

      listEl.insertBefore(li, listEl.firstElementChild);
    }

    function esc(s) {
      return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
    }

    function fmtNow() {
      return new Date().toLocaleString("ja-JP", { month: "numeric", day: "numeric", hour: "2-digit", minute: "2-digit" });
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const name = nameEl.value.trim() || "Anonymous";
      const body = bodyEl.value.trim();

      if (!body) return;

      btn.disabled = true;
      try {
        const res = await fetch("/api/board", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ name, body }),
        });

        if (!res.ok) throw new Error("Erreur");

        prependPost(name, body, fmtNow());
        nameEl.value = "";
        bodyEl.value = "";
        countEl.textContent = "0";
      } catch (err) {
        errEl.textContent = "投稿に失敗しました。";
      } finally {
        btn.disabled = false;
      }
    });
  })();
</script>
