---
import { db } from "../lib/db";

export interface BoardPostRow {
  id: number;
  name: string;
  body: string;
  posted_at: string;
}

const result = await db.execute({
  sql: `SELECT id, name, body, posted_at
        FROM BoardPost
        ORDER BY posted_at DESC
        LIMIT 50`,
  args: [],
});

const posts: BoardPostRow[] = result.rows.map((r) => ({
  id:        Number(r[0]),
  name:      String(r[1]),
  body:      String(r[2]),
  posted_at: String(r[3]),
}));

function fmtTime(iso: string) {
  const d = new Date(iso);
  if (isNaN(d.getTime())) return iso;
  return d.toLocaleString("ja-JP", {
    month: "numeric",
    day:   "numeric",
    hour:  "2-digit",
    minute:"2-digit",
  });
}
---

<section class="board">
  <h2 class="board-title">掲示板</h2>

  <ol class="post-list" id="post-list">
    {posts.length === 0 && (
      <li class="empty">まだ投稿がありません。</li>
    )}
    {posts.map((p) => (
      <li class="post" data-id={p.id}>
        <div class="post-meta">
          <span class="post-name">{p.name}</span>
          <time class="post-time" datetime={p.posted_at}>{fmtTime(p.posted_at)}</time>
        </div>
        <p class="post-body">{p.body}</p>
      </li>
    ))}
  </ol>

  <form class="board-form" id="board-form" novalidate>
    <input
      id="inp-name"
      class="board-input"
      type="text"
      placeholder="名前（任意）"
      maxlength="50"
      autocomplete="nickname"
    />
    <input
      id="inp-body"
      class="board-input"
      type="text"
      placeholder="メッセージ（必須）"
      maxlength="400"
      autocomplete="off"
      required
    />
    <div class="form-footer">
      <span class="char-hint"><span id="char-count">0</span> / 400</span>
      <button type="submit" class="board-btn" id="board-btn">投稿</button>
    </div>
    <p class="form-error" id="form-error" aria-live="polite"></p>
  </form>
</section>

<style>
  .board {
    --ink:    #0f0f0f;
    --muted:  #888;
    --border: #d4d4d4;
    --bg:     #fafafa;
    font-family: "Geist Mono", ui-monospace, monospace;
    color: var(--ink);
  }

  @media (prefers-color-scheme: dark) {
    .board {
      --ink:    #e8e8e8;
      --muted:  #666;
      --border: #2e2e2e;
      --bg:     #111;
    }
  }

  .board-title {
    font-family: "Instrument Serif", Georgia, serif;
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--ink);
    border-bottom: 1px solid var(--ink);
    padding-bottom: .4rem;
    margin-bottom: 1.25rem;
  }

  /* posts */
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
  }

  .post {
    padding: .65rem 0;
    border-bottom: 0.5px solid var(--border);
  }

  .post:first-child { border-top: 0.5px solid var(--border); }

  .post-meta {
    display: flex;
    gap: .6rem;
    align-items: baseline;
    margin-bottom: .2rem;
  }

  .post-name {
    font-size: .72rem;
    font-weight: 500;
    color: var(--ink);
  }

  .post-time {
    font-size: .65rem;
    color: var(--muted);
  }

  .post-body {
    font-size: .78rem;
    line-height: 1.65;
    color: var(--ink);
    margin: 0;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .empty {
    font-size: .75rem;
    color: var(--muted);
    padding: .5rem 0;
  }

  /* form */
  .board-form {
    display: flex;
    flex-direction: column;
    gap: .45rem;
  }

  .board-input {
    font-family: inherit;
    font-size: .78rem;
    background: var(--bg);
    color: var(--ink);
    border: 0.5px solid var(--border);
    padding: .45rem .6rem;
    outline: none;
    transition: border-color .15s;
    border-radius: 0;
    width: 100%;
  }

  .board-input:focus {
    border-color: var(--ink);
  }

  .form-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .char-hint {
    font-size: .65rem;
    color: var(--muted);
  }

  .board-btn {
    font-family: inherit;
    font-size: .72rem;
    background: var(--ink);
    color: var(--bg);
    border: none;
    padding: .4rem .9rem;
    cursor: pointer;
    letter-spacing: .04em;
    transition: opacity .15s;
  }

  .board-btn:hover  { opacity: .75; }
  .board-btn:active { opacity: .6;  }
  .board-btn:disabled { opacity: .4; cursor: not-allowed; }

  .form-error {
    font-size: .68rem;
    color: #c0392b;
    min-height: 1em;
    margin: 0;
  }
</style>

<script>
  (function () {
    const form    = document.getElementById("board-form")    as HTMLFormElement;
    const nameEl  = document.getElementById("inp-name")      as HTMLInputElement;
    const bodyEl  = document.getElementById("inp-body")      as HTMLInputElement;
    const btn     = document.getElementById("board-btn")     as HTMLButtonElement;
    const errEl   = document.getElementById("form-error")    as HTMLParagraphElement;
    const listEl  = document.getElementById("post-list")     as HTMLOListElement;
    const countEl = document.getElementById("char-count")    as HTMLSpanElement;

    bodyEl.addEventListener("input", () => {
      countEl.textContent = String(bodyEl.value.length);
    });

    function fmtNow(): string {
      return new Date().toLocaleString("ja-JP", {
        month:  "numeric",
        day:    "numeric",
        hour:   "2-digit",
        minute: "2-digit",
      });
    }

    function prependPost(name: string, body: string, postedAt: string) {
      const emptyEl = listEl.querySelector(".empty");
      if (emptyEl) emptyEl.remove();

      const li = document.createElement("li");
      li.className = "post";
      li.innerHTML = `
        <div class="post-meta">
          <span class="post-name">${esc(name)}</span>
          <time class="post-time">${esc(postedAt)}</time>
        </div>
        <p class="post-body">${esc(body)}</p>
      `;

      const first = listEl.firstElementChild;
      if (first) {
        listEl.insertBefore(li, first);
      } else {
        listEl.appendChild(li);
      }
    }

    function esc(s: string): string {
      return s
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;");
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      errEl.textContent = "";

      const name = nameEl.value.trim() || "Anonymous";
      const body = bodyEl.value.trim();

      if (!body) {
        errEl.textContent = "メッセージを入力してください。";
        bodyEl.focus();
        return;
      }

      btn.disabled = true;
      btn.textContent = "送信中…";

      try {
        const res = await fetch("/api/board", {
          method:  "POST",
          headers: { "Content-Type": "application/json" },
          body:    JSON.stringify({ name, body }),
        });

        if (!res.ok) {
          const json = await res.json().catch(() => ({}));
          throw new Error((json as { error?: string }).error ?? `HTTP ${res.status}`);
        }

        prependPost(name, body, fmtNow());
        nameEl.value  = "";
        bodyEl.value  = "";
        countEl.textContent = "0";
      } catch (err) {
        errEl.textContent =
          err instanceof Error ? err.message : "投稿に失敗しました。";
      } finally {
        btn.disabled = false;
        btn.textContent = "投稿";
      }
    });
  })();
</script>
