---
// src/components/Board.astro
// サーバーサイドで Astro DB から投稿を取得し SSR レンダリング。
// クライアント側は Vanilla JS で fetch → DOM 追加（フレームワーク不要）。

import { db, BoardPost, desc } from "astro:db";
import Layout from "@/layouts/Layout.astro"

const posts = await db
  .select()
  .from(BoardPost)
  .orderBy(desc(BoardPost.postedAt))
  .limit(50);

function fmtDate(d: Date | string | null): string {
  if (!d) return "";
  const dt = d instanceof Date ? d : new Date(d);
  if (isNaN(dt.getTime())) return String(d);
  return dt.toLocaleString("ja-JP", {
    month:  "numeric",
    day:    "numeric",
    hour:   "2-digit",
    minute: "2-digit",
  });
}
---
<Layout>
<section class="board">
  <h2 class="board-title">掲示板</h2>

  <ol class="post-list" id="post-list">
    {posts.length === 0 && (
      <li class="post-empty">まだ投稿がありません。</li>
    )}
    {posts.map((p) => (
      <li class="post">
        <div class="post-meta">
          <span class="post-name">{p.name}</span>
          <time class="post-time" datetime={String(p.postedAt)}>
            {fmtDate(p.postedAt)}
          </time>
        </div>
        <p class="post-body">{p.body}</p>
      </li>
    ))}
  </ol>

  <form class="board-form" id="board-form" novalidate>
    <input
      id="inp-name"
      class="board-input"
      type="text"
      placeholder="名前（任意）"
      maxlength="50"
      autocomplete="nickname"
    />
    <input
      id="inp-body"
      class="board-input"
      type="text"
      placeholder="メッセージ（必須）"
      maxlength="400"
      autocomplete="off"
      required
    />
    <div class="form-row">
      <span class="char-hint">
        <span id="char-count">0</span> / 400
      </span>
      <button type="submit" id="board-btn" class="board-btn">投稿</button>
    </div>
    <p class="form-error" id="form-error" aria-live="polite"></p>
  </form>
</section>
</Layout>
<style>
  /* ── Google Fonts は layout 側で読み込んでください ──
     Instrument Serif / Geist Mono                        */

  .board {
    --ink:    #111;
    --muted:  #999;
    --line:   #e0e0e0;
    --bg-in:  #f7f7f7;
  }

  @media (prefers-color-scheme: dark) {
    .board {
      --ink:   #e4e4e4;
      --muted: #666;
      --line:  #2a2a2a;
      --bg-in: #1a1a1a;
    }
  }

  .board {
    font-family: "Geist Mono", ui-monospace, monospace;
    color: var(--ink);
  }

  /* タイトル */
  .board-title {
    font-family: "Instrument Serif", Georgia, serif;
    font-size: 1.3rem;
    font-weight: 400;
    border-bottom: 1px solid var(--ink);
    padding-bottom: .35rem;
    margin-bottom: 1.1rem;
  }

  /* 投稿リスト */
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.4rem;
  }

  .post {
    padding: .6rem 0;
    border-bottom: .5px solid var(--line);
  }
  .post:first-child { border-top: .5px solid var(--line); }

  .post-meta {
    display: flex;
    gap: .55rem;
    align-items: baseline;
    margin-bottom: .15rem;
  }

  .post-name {
    font-size: .7rem;
    font-weight: 500;
  }

  .post-time {
    font-size: .64rem;
    color: var(--muted);
  }

  .post-body {
    font-size: .76rem;
    line-height: 1.65;
    margin: 0;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .post-empty {
    font-size: .74rem;
    color: var(--muted);
    padding: .4rem 0;
  }

  /* フォーム */
  .board-form {
    display: flex;
    flex-direction: column;
    gap: .4rem;
  }

  .board-input {
    font-family: inherit;
    font-size: .76rem;
    background: var(--bg-in);
    color: var(--ink);
    border: .5px solid var(--line);
    padding: .42rem .55rem;
    outline: none;
    transition: border-color .12s;
    width: 100%;
    border-radius: 0;
  }
  .board-input:focus { border-color: var(--ink); }

  .form-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .char-hint {
    font-size: .62rem;
    color: var(--muted);
  }

  .board-btn {
    font-family: inherit;
    font-size: .7rem;
    background: var(--ink);
    color: var(--bg-in);
    border: none;
    padding: .38rem .85rem;
    cursor: pointer;
    letter-spacing: .04em;
    transition: opacity .12s;
  }
  .board-btn:hover    { opacity: .72; }
  .board-btn:active   { opacity: .55; }
  .board-btn:disabled { opacity: .38; cursor: not-allowed; }

  .form-error {
    font-size: .65rem;
    color: #b33;
    min-height: 1em;
    margin: 0;
  }
</style>

<script>
  (() => {
    const form    = document.getElementById("board-form");
    const nameEl  = document.getElementById("inp-name")    as HTMLInputElement;
    const bodyEl  = document.getElementById("inp-body")    as HTMLInputElement;
    const btn     = document.getElementById("board-btn")   as HTMLButtonElement;
    const errEl   = document.getElementById("form-error")  as HTMLParagraphElement;
    const listEl  = document.getElementById("post-list")   as HTMLOListElement;
    const countEl = document.getElementById("char-count")  as HTMLSpanElement;

    // ── 文字カウンタ ──────────────────────────────────────
    bodyEl.addEventListener("input", () => {
      countEl.textContent = String(bodyEl.value.length);
    });

    // ── 投稿追加（楽観的 UI）────────────────────────────────
    function prependPost(name: string, body: string, postedAt: string) {
      // 「まだ投稿がありません」行を削除
      listEl.querySelector(".post-empty")?.remove();

      const li = document.createElement("li");
      li.className = "post";
      li.innerHTML =
        `<div class="post-meta">` +
          `<span class="post-name">${esc(name)}</span>` +
          `<time class="post-time">${esc(postedAt)}</time>` +
        `</div>` +
        `<p class="post-body">${esc(body)}</p>`;

      // 先頭に挿入（border-top のため :first-child が当たるように）
      listEl.insertBefore(li, listEl.firstElementChild);
    }

    // ── HTML エスケープ ───────────────────────────────────
    function esc(s: string): string {
      return s
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;");
    }

    // ── 日時フォーマット ──────────────────────────────────
    function fmtNow(): string {
      return new Date().toLocaleString("ja-JP", {
        month:  "numeric",
        day:    "numeric",
        hour:   "2-digit",
        minute: "2-digit",
      });
    }

    // ── submit ────────────────────────────────────────────
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      errEl.textContent = "";

      const name = nameEl.value.trim() || "Anonymous";
      const body = bodyEl.value.trim();

      if (!body) {
        errEl.textContent = "メッセージを入力してください。";
        bodyEl.focus();
        return;
      }

      btn.disabled    = true;
      btn.textContent = "送信中…";

      try {
        const res = await fetch("/api/board", {
          method:  "POST",
          headers: { "Content-Type": "application/json" },
          body:    JSON.stringify({ name, body }),
        });

        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(
            (data as { error?: string }).error ?? `エラー (HTTP ${res.status})`
          );
        }

        // 成功 → 楽観的に DOM へ追加
        prependPost(name, body, fmtNow());
        nameEl.value        = "";
        bodyEl.value        = "";
        countEl.textContent = "0";
      } catch (err) {
        errEl.textContent =
          err instanceof Error ? err.message : "投稿に失敗しました。";
      } finally {
        btn.disabled    = false;
        btn.textContent = "投稿";
      }
    });
  })();
</script>
