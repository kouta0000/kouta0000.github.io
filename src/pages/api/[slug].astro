---
// src/pages/blog/[slug].astro
import type { GetStaticPaths } from "astro";
import Comments from "../../components/Comments.astro";

export const getStaticPaths = (async () => {
  // 実際のプロジェクトでは、CMSやmdxから取得
  return [
    { params: { slug: "hello-world" }, props: { title: "Hello World" } },
    { params: { slug: "astro-db-guide" }, props: { title: "Astro DB ガイド" } },
  ];
}) satisfies GetStaticPaths;

const { slug } = Astro.params;
const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
</head>
<body class="bg-white dark:bg-zinc-950 min-h-screen">
  <main class="max-w-2xl mx-auto px-4 py-16">
    <article class="mb-8">
      <h1 class="text-3xl font-bold text-zinc-900 dark:text-zinc-50 mb-4">
        {title}
      </h1>
      <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed">
        記事の本文がここに入ります...
      </p>
    </article>

    <!-- コメントセクション：postSlug を渡すだけ -->
    <Comments postSlug={slug} />
  </main>
</body>
</html>
