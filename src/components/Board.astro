---
// 1. サーバーサイドレンダリングを強制（リロードのたびにDBを読み直す）
export const prerender = false;

import { db, BoardPost, asc } from "astro:db";
import Layout from "@/layouts/Layout.astro";

// 2. サーバー側で全データを「古い順」に取得
const posts = await db
  .select()
  .from(BoardPost)
  .orderBy(asc(BoardPost.postedAt));

const styles = {
  post: "py-5 border-b border-[#eee] dark:border-[#222]",
  meta: "flex gap-2 items-baseline mb-1",
  name: "text-[0.7rem] font-bold uppercase tracking-wider text-[#111] dark:text-[#eee]",
  time: "text-[0.62rem] text-[#aaa] font-mono",
  body: "text-[1.15rem] leading-relaxed whitespace-pre-wrap break-words text-[#333] dark:text-[#ccc]",
  input: "font-mono text-[1rem] bg-[#f9f9f9] dark:bg-[#111] text-[#111] dark:text-[#eee] border border-[#eee] dark:border-[#333] px-4 py-3 outline-none focus:border-[#111] dark:focus:border-[#eee] w-full rounded-none transition-colors"
};
---

<Layout title="BBS">
  <section class="max-w-2xl mx-auto px-2 py-2 font-mono">
    
    <ol class="list-none p-0 m-0 mb-16 space-y-2" id="post-list">
      {posts.map((p, i) => (
        <li class={styles.post}>
          <div class={styles.meta}>
            <span class="text-[#999] text-[0.7rem]">{i + 1}.</span>
            <span class={styles.name}>{p.name || "Anonymous"}</span>
            <time class={styles.time}>
              {p.postedAt.toLocaleString("ja-JP", { month: "numeric", day: "numeric", hour: "2-digit", minute: "2-digit" })}
            </time>
          </div>
          <p class={styles.body}>{p.body}</p>
        </li>
      ))}
    </ol>
    
    {posts.length === 0 && (
      <div class="text-xs text-[#aaa] tracking-widest text-center py-10 uppercase">
        NO POSTS YET.
      </div>
    )}

    <form id="board-form" class="flex flex-col gap-2 border-t pt-8 border-[#eee] dark:border-[#222]">
      <input id="inp-name" name="name" class={styles.input} type="text" placeholder="NAME (OPTIONAL)" maxlength="50" />
      <textarea id="inp-body" name="body" class={`${styles.input} min-h-[150px] resize-y`} placeholder="ENTER MESSAGE..." maxlength="400" required></textarea>
      
      <div class="flex justify-between items-center">
        <span class="text-[0.65rem] text-[#aaa] font-bold">
          <span id="char-count">0</span> / 400
        </span>
        <button type="submit" id="board-btn" class="bg-[#111] dark:bg-[#eee] text-white dark:text-[#111] px-12 py-4 text-[0.7rem] font-black hover:bg-[#333] dark:hover:bg-[#ccc] transition-all active:scale-95">
          投稿
        </button>
      </div>
      <p id="form-error" class="text-[0.65rem] text-red-500 italic mt-2"></p>
    </form>
  </section>
</Layout>

<script>
  const form = document.getElementById("board-form");
  const bodyInput = document.getElementById("inp-body");
  const charCount = document.getElementById("char-count");
  const submitBtn = document.getElementById("board-btn");

  // 3. 投稿処理
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    
    const name = document.getElementById("inp-name").value.trim();
    const body = bodyInput.value.trim();
    if (!body) return;

    submitBtn.disabled = true;
    submitBtn.textContent = "SENDING...";

    try {
      const res = await fetch("/api/board", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name, body })
      });

      if (!res.ok) throw new Error();

      // 【重要】投稿に成功したら、ページをリロードする。
      // これにより、サーバー側の最新データ(initialPosts)が確実に読み込まれる。
      window.location.reload();

    } catch (err) {
      document.getElementById("form-error").textContent = "FAILED TO POST.";
      submitBtn.disabled = false;
      submitBtn.textContent = "投稿";
    }
  });

  bodyInput?.addEventListener("input", () => {
    charCount.textContent = bodyInput.value.length;
  });
</script>
