---
import { db, BoardPost, desc } from "astro:db";
import Layout from "@/layouts/Layout.astro";

// 1. API(GET)と同じく desc(降順/新しい順) で取得する
const rawPosts = await db
  .select()
  .from(BoardPost)
  .orderBy(desc(BoardPost.postedAt))
  .limit(50);

// 2. 表示要件である「1, 2, 3... (古い順)」に並べ替える
const initialPosts = rawPosts.reverse();

const styles = {
  post: "py-5 border-b border-[#eee] dark:border-[#222] transition-all duration-500",
  meta: "flex gap-2 items-baseline mb-1",
  name: "text-[0.7rem] font-bold uppercase tracking-wider text-[#111] dark:text-[#eee]",
  time: "text-[0.62rem] text-[#aaa] font-mono",
  body: "text-[1.15rem] leading-relaxed whitespace-pre-wrap break-words text-[#333] dark:text-[#ccc]",
  input: "font-mono text-[1rem] bg-[#f9f9f9] dark:bg-[#111] text-[#111] dark:text-[#eee] border border-[#eee] dark:border-[#333] px-4 py-3 outline-none focus:border-[#111] dark:focus:border-[#eee] w-full rounded-none transition-colors"
};
---

<Layout title="BBS">
  <section class="max-w-2xl mx-auto px-2 py-2 font-mono">
    
    <ol class="list-none p-0 m-0 mb-16 space-y-2" id="post-list">
      {initialPosts.map((p, i) => (
        <li class={styles.post} style="opacity: 1; transform: translateY(0);">
          <div class={styles.meta}>
            <span class="text-[#999] text-[0.7rem]">{i + 1}.</span>
            <span class={styles.name}>{p.name}</span>
            <time class={styles.time}>{p.postedAt.toLocaleString("ja-JP")}</time>
          </div>
          <p class={styles.body}>{p.body}</p>
        </li>
      ))}
    </ol>
    
    <div id="status-msg" class={`text-xs text-[#aaa] tracking-widest text-center py-10 uppercase ${initialPosts.length > 0 ? 'hidden' : ''}`}>
      {initialPosts.length === 0 ? "NO POSTS YET." : "Loading..."}
    </div>

    <form id="board-form" class="flex flex-col gap-2 border-t pt-4 border-[#eee] dark:border-[#222]">
      <input id="inp-name" class={styles.input} type="text" placeholder="NAME (OPTIONAL)" maxlength="50" />
      <textarea id="inp-body" class={`${styles.input} min-h-[150px] resize-y`} placeholder="ENTER MESSAGE..." maxlength="400" required></textarea>
      
      <div class="flex justify-between items-center">
        <span class="text-[0.65rem] text-[#aaa] font-bold">
          <span id="char-count">0</span> / 400
        </span>
        <button type="submit" id="board-btn" class="bg-[#111] dark:bg-[#eee] text-white dark:text-[#111] px-12 py-4 text-[0.7rem] font-black hover:bg-[#333] dark:hover:bg-[#ccc] transition-all active:scale-95 disabled:opacity-20">
          投稿
        </button>
      </div>
      <p id="form-error" class="text-[0.65rem] text-red-500 italic mt-2 min-h-[1em]"></p>
    </form>
  </section>
</Layout>

<script define:vars={{ styles }}>
  const list = document.getElementById("post-list");
  const form = document.getElementById("board-form");
  const statusMsg = document.getElementById("status-msg");
  const bodyInput = document.getElementById("inp-body");
  const charCount = document.getElementById("char-count");
  const errorMsg = document.getElementById("form-error");
  const submitBtn = document.getElementById("board-btn");

  const h = (s) => String(s || "").replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
  const f = (d) => new Intl.DateTimeFormat("ja-JP", {
    month: "numeric", day: "numeric", hour: "2-digit", minute: "2-digit"
  }).format(new Date(d));

  function createPostNode(p, index) {
    const li = document.createElement("li");
    li.className = styles.post;
    li.style.opacity = "1";
    li.style.transform = "translateY(0)";
    li.innerHTML = `
      <div class="${styles.meta}">
        <span class="text-[#999] text-[0.7rem]">${index}.</span>
        <span class="${styles.name}">${h(p.name)}</span>
        <time class="${styles.time}">${f(p.postedAt)}</time>
      </div>
      <p class="${styles.body}">${h(p.body)}</p>
    `;
    return li;
  }

  // クライアント側での再取得は、SSRで漏れた最新分がある場合のみ必要
  async function fetchAndRender() {
    // 既にリストがある場合は、二重リクエストを避けるため何もしない
    if (list.children.length > 0) return;

    try {
      const res = await fetch("/api/board");
      const data = await res.json();
      const posts = (data.posts || []).reverse();
      if (posts.length > 0) {
        statusMsg.classList.add("hidden");
        list.innerHTML = "";
        posts.forEach((p, i) => list.appendChild(createPostNode(p, i + 1)));
      }
    } catch (e) { console.error(e); }
  }

  bodyInput.addEventListener("input", () => {
    charCount.textContent = bodyInput.value.length;
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const name = document.getElementById("inp-name").value.trim() || "Anonymous";
    const body = bodyInput.value.trim();
    if (!body) return;

    submitBtn.disabled = true;
    errorMsg.textContent = "";

    try {
      const res = await fetch("/api/board", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name, body })
      });

      if (!res.ok) throw new Error();
      const data = await res.json();
      const newPost = data.post;

      const newIdx = list.children.length + 1;
      const node = createPostNode(newPost, newIdx);
      list.appendChild(node);
      
      form.reset();
      charCount.textContent = "0";
      statusMsg.classList.add("hidden");
    } catch (err) {
      errorMsg.textContent = "FAILED TO POST.";
    } finally {
      submitBtn.disabled = false;
    }
  });

  fetchAndRender();
</script>

<style>
  .hidden { display: none !important; }
</style>
