---
// src/components/Comments.astro
interface Props {
  postSlug: string;
}
const { postSlug } = Astro.props;
// DBアクセスなし・サーバー処理なし
---

<section class="comments-section">
  <div class="comments-header">
    <span class="comments-label">COMMENTS</span>
    <span id="comment-count" class="comment-count">0 件</span>
  </div>

  <div class="comment-form-wrapper">
    <h3 class="form-title">LEAVE A COMMENT</h3>
    <form id="comment-form" novalidate>
      <div class="form-grid">
        <div class="field-group">
          <label for="author" class="field-label">
            なまえ <span class="required">*</span>
          </label>
          <input
            id="author" name="author" type="text" required maxlength="50" placeholder="田中 太郎"
            class="field-input"
          />
          <p class="field-error hidden"></p>
        </div>
        <div class="field-group">
          <label for="email" class="field-label">
            メール <span class="optional">（任意）</span>
          </label>
          <input
            id="email" name="email" type="email" placeholder="hello@example.com"
            class="field-input"
          />
        </div>
      </div>
      <div class="field-group">
        <label for="body" class="field-label">
          コメント <span class="required">*</span>
        </label>
        <textarea
          id="body" name="body" required maxlength="1000" rows="4" placeholder="感想・ご意見をどうぞ..."
          class="field-input field-textarea"
        ></textarea>
        <div class="textarea-footer">
          <p class="field-error hidden"></p>
          <span class="char-counter">0 / 1000</span>
        </div>
      </div>
      <div class="form-actions">
        <button type="submit" id="submit-btn" class="submit-btn">
          <span class="btn-label">投稿する →</span>
          <svg class="btn-spinner hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path>
          </svg>
        </button>
        <p id="form-success" class="hidden form-success">✓ コメントを投稿しました</p>
        <p id="form-error" class="hidden form-error-msg"></p>
      </div>
    </form>
  </div>

  <ul id="comment-list" class="comment-list"></ul>

  <p id="empty-state" class="empty-state">
    まだコメントはありません。最初のコメントを書いてみましょう。
  </p>
</section>

<script define:vars={{ postSlug }}>
function avatarColor(name) {
  const colors = ["#6366f1","#8b5cf6","#ec4899","#f43f5e","#f97316","#eab308","#22c55e","#14b8a6","#0ea5e9"];
  let hash = 0;
  for (const ch of name) hash = (hash * 31 + ch.charCodeAt(0)) & 0xffffffff;
  return colors[Math.abs(hash) % colors.length];
}

function formatDate(iso) {
  return new Intl.DateTimeFormat("ja-JP", {
    year: "numeric", month: "long", day: "numeric", hour: "2-digit", minute: "2-digit",
  }).format(new Date(iso));
}

function escHtml(str) {
  return str.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
}

const form        = document.getElementById("comment-form");
const authorEl    = document.getElementById("author");
const emailEl     = document.getElementById("email");
const bodyEl      = document.getElementById("body");
const submitBtn   = document.getElementById("submit-btn");
const btnLabel    = submitBtn.querySelector(".btn-label");
const btnSpinner  = submitBtn.querySelector(".btn-spinner");
const formSuccess = document.getElementById("form-success");
const formError   = document.getElementById("form-error");
const commentList = document.getElementById("comment-list");
const emptyState  = document.getElementById("empty-state");
const countEl     = document.getElementById("comment-count");
const counter     = document.querySelector(".char-counter");

// 文字数カウンター
bodyEl.addEventListener("input", () => {
  const len = bodyEl.value.length;
  counter.textContent = `${len} / 1000`;
  counter.classList.toggle("char-counter--warn", len > 900);
});

function setFieldError(input, msg) {
  const errEl = input.closest(".field-group")?.querySelector(".field-error");
  if (!errEl) return;
  if (msg) {
    errEl.textContent = msg;
    errEl.classList.remove("hidden");
    input.classList.add("field-input--error");
  } else {
    errEl.classList.add("hidden");
    input.classList.remove("field-input--error");
  }
}

function clearErrors() {
  [authorEl, emailEl, bodyEl].forEach(el => setFieldError(el, ""));
  formSuccess.classList.add("hidden");
  formError.classList.add("hidden");
}

function buildCommentEl(c) {
  const li = document.createElement("li");
  li.style.cssText = "display:flex;gap:0.875rem;padding:1.375rem 0;border-bottom:0.5px solid #e4e4e7;animation:slideIn 0.3s ease forwards;";
  li.dataset.id = c.id;
  li.innerHTML = `
    <div aria-hidden="true" style="flex-shrink:0;width:2rem;height:2rem;min-width:2rem;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;color:#fff;margin-top:0.125rem;user-select:none;background:${avatarColor(c.author)}">${c.author.charAt(0).toUpperCase()}</div>
    <div style="flex:1;min-width:0;">
      <div style="display:flex;align-items:baseline;gap:0.625rem;margin-bottom:0.375rem;">
        <span style="font-size:0.8125rem;font-weight:500;color:#18181b;">${escHtml(c.author)}</span>
        <time style="font-size:0.6875rem;color:#a1a1aa;font-family:monospace;">${formatDate(c.createdAt)}</time>
      </div>
      <p style="font-size:0.875rem;line-height:1.7;color:#52525b;white-space:pre-wrap;word-break:break-word;margin:0;">${escHtml(c.body)}</p>
    </div>`;
  return li;
}

// 初期ロード
async function loadComments() {
  try {
    const res = await fetch(`/api/comments/${postSlug}`);
    const comments = await res.json();
    if (comments.length > 0) {
      emptyState.remove();
      comments.forEach(c => commentList.appendChild(buildCommentEl(c)));
      countEl.textContent = `${comments.length} 件`;
    }
  } catch (e) {
    console.error("コメント取得エラー", e);
  }
}
loadComments();

// 投稿
form.addEventListener("submit", async (e) => {
  e.preventDefault();
  clearErrors();

  const author = authorEl.value.trim();
  const email  = emailEl.value.trim();
  const body   = bodyEl.value.trim();

  let hasError = false;
  if (!author) { setFieldError(authorEl, "名前を入力してください"); hasError = true; }
  if (!body)   { setFieldError(bodyEl,   "コメントを入力してください"); hasError = true; }
  if (hasError) return;

  submitBtn.disabled = true;
  btnLabel.textContent = "送信中...";
  btnSpinner.classList.remove("hidden");

  try {
    const res = await fetch(`/api/comments/${postSlug}`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ author, email: email || undefined, body }),
    });
    const data = await res.json();
    if (!res.ok) {
      formError.textContent = data.error || "投稿に失敗しました";
      formError.classList.remove("hidden");
      return;
    }
    form.reset();
    counter.textContent = "0 / 1000";
    formSuccess.classList.remove("hidden");
    setTimeout(() => formSuccess.classList.add("hidden"), 4000);

    const li = buildCommentEl(data);
    li.style.opacity = "0";
    li.style.transform = "translateY(-8px)";
    li.style.transition = "opacity 0.3s ease, transform 0.3s ease";
    commentList.prepend(li);
    requestAnimationFrame(() => { li.style.opacity = "1"; li.style.transform = "translateY(0)"; });

    const prev = parseInt(countEl.textContent, 10) || 0;
    countEl.textContent = `${prev + 1} 件`;
  } catch (err) {
    formError.textContent = `エラー: ${err.message}`;
    formError.classList.remove("hidden");
  } finally {
    submitBtn.disabled = false;
    btnLabel.textContent = "投稿する →";
    btnSpinner.classList.add("hidden");
  }
});
</script>

<style>
  /* ── セクション ── */
  .comments-section {
    margin-top: 4rem;
    padding-top: 2.5rem;
    border-top: 1px solid #e4e4e7;
  }
  :global(.dark) .comments-section {
    border-top-color: #27272a;
  }

  /* ── ヘッダー ── */
  .comments-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }
  .comments-label {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: #71717a;
  }
  :global(.dark) .comments-label { color: #52525b; }
  .comment-count {
    font-size: 0.6875rem;
    font-family: monospace;
    color: #a1a1aa;
  }
  :global(.dark) .comment-count { color: #52525b; }

  /* ── 投稿フォーム ── */
  .comment-form-wrapper {
    margin-bottom: 3rem;
    border: 0.5px solid #d4d4d8;
    padding: 1.5rem;
  }
  :global(.dark) .comment-form-wrapper {
    border-color: #3f3f46;
    background: #18181b;
  }
  .form-title {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: #a1a1aa;
    margin: 0 0 1.25rem;
  }
  :global(.dark) .form-title { color: #52525b; }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  @media (max-width: 480px) {
    .form-grid { grid-template-columns: 1fr; }
  }

  .field-group { display: flex; flex-direction: column; margin-bottom: 0.75rem; }
  .field-label {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: #71717a;
    margin-bottom: 0.375rem;
  }
  :global(.dark) .field-label { color: #71717a; }
  .required { color: #fca5a5; }
  .optional { color: #a1a1aa; font-weight: 400; }

  .field-input {
    width: 40%;
    box-sizing: border-box;
    border: 0.5px solid #d4d4d8;
    border-radius: 0;
    background: #fff;
    padding: 0.625rem 0.75rem;
    font-size: 0.875rem;
    color: #18181b;
    font-family: inherit;
    transition: border-color 0.15s;
    outline: none;
  }
  .field-input::placeholder { color: #d4d4d8; }
  .field-input:focus { border-color: #18181b; }
  .field-input--error { border-color: #fca5a5; }
  :global(.dark) .field-input {
    background: #27272a;
    border-color: #3f3f46;
    color: #f4f4f5;
  }
  :global(.dark) .field-input::placeholder { color: #52525b; }
  :global(.dark) .field-input:focus { border-color: #f4f4f5; }

  .field-textarea { resize: vertical; line-height: 1.7; }

  .textarea-footer {
    display: flex;
    justify-content: flex-end;
    margin-top: 0.25rem;
  }
  .char-counter { font-size: 0.6875rem; color: #a1a1aa; font-family: monospace; }
  .char-counter--warn { color: #fca5a5; }

  .field-error {
    font-size: 0.6875rem;
    color: #f87171;
    margin-top: 0.25rem;
  }
  .hidden { display: none !important; }

  /* ── 送信ボタン ── */
  .form-actions { display: flex; align-items: center; gap: 1rem; margin-top: 1rem; }
  .submit-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #18181b;
    color: #fafafa;
    border: none;
    border-radius: 0;
    padding: 0.625rem 1.25rem;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .submit-btn:hover { opacity: 0.85; }
  .submit-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  :global(.dark) .submit-btn {
    background: #f4f4f5;
    color: #18181b;
  }
  .btn-spinner {
    width: 1rem;
    height: 1rem;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .form-success { font-size: 0.8125rem; color: #34d399; font-weight: 500; }
  .form-error-msg { font-size: 0.8125rem; color: #f87171; font-weight: 500; }

  /* ── コメント一覧 ── */
  .comment-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .comment-item {
    display: flex;
    gap: 0.875rem;
    padding: 1.375rem 0;
    border-bottom: 0.5px solid #e4e4e7;
    animation: slideIn 0.3s ease forwards;
  }
  :global(.dark) .comment-item { border-bottom-color: #27272a; }

  .comment-avatar {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    color: #fff;
    margin-top: 0.125rem;
    user-select: none;
  }
  .comment-body { flex: 1; min-width: 0; }
  .comment-meta {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
    margin-bottom: 0.375rem;
  }
  .comment-author {
    font-size: 0.8125rem;
    font-weight: 500;
    color: #18181b;
  }
  :global(.dark) .comment-author { color: #f4f4f5; }
  .comment-time {
    font-size: 0.6875rem;
    color: #a1a1aa;
    font-family: monospace;
  }
  :global(.dark) .comment-time { color: #52525b; }
  .comment-text {
    font-size: 0.875rem;
    line-height: 1.7;
    color: #52525b;
    white-space: pre-wrap;
    word-break: break-word;
    margin: 0;
  }
  :global(.dark) .comment-text { color: #a1a1aa; }

  /* ── 空状態 ── */
  .empty-state {
    text-align: center;
    font-size: 0.8125rem;
    color: #a1a1aa;
    padding: 2.5rem 0;
  }
  :global(.dark) .empty-state { color: #52525b; }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
