---
/**
 * RelatedPosts.astro
 * タグの重複度に基づいて関連記事を表示するコンポーネント
 *
 * Usage:
 *   import RelatedPosts from "@/components/RelatedPosts.astro";
 *   <RelatedPosts currentPost={post} posts={posts} maxItems={3} />
 *
 * Props:
 *   currentPost : CollectionEntry<"blog">  — 現在の記事
 *   posts       : CollectionEntry<"blog">[]— 全記事一覧
 *   maxItems?   : number                   — 表示件数（デフォルト: 3）
 */

import type { CollectionEntry } from "astro:content";
import Tag from "@/components/Tag.astro";
import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";

type Props = {
  currentPost: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
  maxItems?: number;
};

const { currentPost, posts, maxItems = 3 } = Astro.props;

// --- 関連記事スコアリング ---
// タグの重複数 + 同じ著者ならボーナス
const currentTags = new Set(currentPost.data.tags?.map(t => t.toLowerCase()) ?? []);

type ScoredPost = {
  post: CollectionEntry<"blog">;
  score: number;
  sharedTags: string[];
};

const scored: ScoredPost[] = posts
  .filter(p => p.id !== currentPost.id)
  .map(p => {
    const pTags = p.data.tags?.map(t => t.toLowerCase()) ?? [];
    const sharedTags = pTags.filter(t => currentTags.has(t));
    const authorBonus = p.data.author === currentPost.data.author ? 0.5 : 0;
    return {
      post: p,
      score: sharedTags.length + authorBonus,
      sharedTags,
    };
  })
  .filter(s => s.score > 0)                          // 関連性のあるものだけ
  .sort((a, b) => b.score - a.score || 
    // 同スコアなら新しい順
    new Date(b.post.data.pubDatetime).getTime() -
    new Date(a.post.data.pubDatetime).getTime()
  )
  .slice(0, maxItems);

const hasRelated = scored.length > 0;
---

{
  hasRelated && (
    <section class="related-posts" aria-label="関連記事">
      <div class="related-posts__header">
        <span class="related-posts__eyebrow" aria-hidden="true">✦</span>
        <h2 class="related-posts__title">関連記事</h2>
        <span class="related-posts__eyebrow" aria-hidden="true">✦</span>
      </div>

      <ul class="related-posts__list" role="list">
        {scored.map(({ post, sharedTags }, index) => {
          const href = getPath(post.id, post.filePath);
          const pubDate = new Date(post.data.pubDatetime);
          const dateStr = pubDate.toLocaleDateString("ja-JP", {
            year: "numeric",
            month: "short",
            day: "numeric",
          });

          return (
            <li
              class="related-posts__item"
              style={`--item-index: ${index};`}
            >
              <a
                href={href}
                class="related-posts__link"
                aria-label={`関連記事: ${post.data.title}`}
              >
                <!-- 番号装飾 -->
                <span class="related-posts__num" aria-hidden="true">
                  {String(index + 1).padStart(2, "0")}
                </span>

                <div class="related-posts__body">
                  <p class="related-posts__post-title">{post.data.title}</p>

                  {post.data.description && (
                    <p class="related-posts__desc">{post.data.description}</p>
                  )}

                  <div class="related-posts__meta">
                    <!-- 日付 -->
                    <time
                      datetime={pubDate.toISOString()}
                      class="related-posts__date"
                    >
                      {dateStr}
                    </time>
                  </div>
                </div>

                <!-- 矢印 -->
                <span class="related-posts__arrow" aria-hidden="true">→</span>
              </a>
            </li>
          );
        })}
      </ul>
    </section>
  )
}

<style>
  /* ==========================================
     関連記事セクション全体
  ========================================== */
  .related-posts {
    margin-block: 2.5rem;
  }

  /* ---- ヘッダー ---- */
  .related-posts__header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1.25rem;
  }

  .related-posts__eyebrow {
    color: var(--color-accent, currentColor);
    opacity: 0.5;
    font-size: 0.65rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .related-posts__title {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-foreground, currentColor);
    opacity: 0.45;
    margin: 0;
    white-space: nowrap;
  }

  .related-posts__header::after {
    content: "";
    display: block;
    flex: 1;
    height: 1px;
    background: currentColor;
    opacity: 0.1;
  }

  /* ---- リスト ---- */
  .related-posts__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ---- 各カード ---- */
  .related-posts__item {
    border-top: 1px dashed;
    border-color: currentColor;
    opacity: 0.15;
    animation: fadeSlideIn 0.35s ease both;
    animation-delay: calc(var(--item-index, 0) * 60ms);
  }

  /* セレクタを分割して重複opacityを回避 */
  .related-posts__item {
    opacity: 1;
    border-color: var(--color-foreground, currentColor);
  }

  /* borderだけ薄くしたいので疑似要素で制御 */
  .related-posts__item {
    position: relative;
  }

  @keyframes fadeSlideIn {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .related-posts__item:last-child {
    border-bottom: 1px dashed;
    border-bottom-color: var(--color-foreground, currentColor);
    opacity: 1; /* リセット */
  }

  /* 実際のborderを薄く */
  .related-posts__item {
    border-top-color: color-mix(in srgb, currentColor 12%, transparent);
  }

  .related-posts__item:last-child {
    border-bottom-color: color-mix(in srgb, currentColor 12%, transparent);
  }

  /* ---- リンク ---- */
  .related-posts__link {
    display: grid;
    grid-template-columns: 2.2rem 1fr auto;
    align-items: start;
    gap: 0.85rem;
    padding: 0.95rem 0.3rem;
    text-decoration: none;
    color: inherit;
    border-radius: 0.25rem;
    transition: background 0.18s ease, padding 0.18s ease;
  }

  .related-posts__link:hover {
    background: color-mix(in srgb, var(--color-accent, currentColor) 5%, transparent);
    padding-inline: 0.65rem;
  }

  /* ---- 番号 ---- */
  .related-posts__num {
    font-size: 0.68rem;
    font-variant-numeric: tabular-nums;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-accent, currentColor);
    opacity: 0.4;
    padding-top: 0.15rem;
    font-family: ui-monospace, "Cascadia Code", monospace;
    transition: opacity 0.18s ease;
  }

  .related-posts__link:hover .related-posts__num {
    opacity: 0.85;
  }

  /* ---- 本文エリア ---- */
  .related-posts__body {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
  }

  /* ---- タイトル ---- */
  .related-posts__post-title {
    margin: 0;
    font-size: 0.92rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-foreground, currentColor);
    transition: color 0.18s ease;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .related-posts__link:hover .related-posts__post-title {
    color: var(--color-accent, currentColor);
  }

  /* ---- 説明文 ---- */
  .related-posts__desc {
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.5;
    opacity: 0.5;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
  }

  /* ---- メタ情報 ---- */
  .related-posts__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.15rem;
  }

  .related-posts__date {
    font-size: 0.72rem;
    opacity: 0.4;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .related-posts__tags {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }

  /* ---- 矢印 ---- */
  .related-posts__arrow {
    font-size: 0.85rem;
    opacity: 0.2;
    padding-top: 0.2rem;
    transition: opacity 0.18s ease, transform 0.18s ease;
    flex-shrink: 0;
    color: var(--color-accent, currentColor);
  }

  .related-posts__link:hover .related-posts__arrow {
    opacity: 0.7;
    transform: translateX(3px);
  }

  /* ==========================================
     レスポンシブ
  ========================================== */
  @media (max-width: 480px) {
    .related-posts__link {
      grid-template-columns: 1.8rem 1fr auto;
      gap: 0.6rem;
    }

    .related-posts__num {
      font-size: 0.62rem;
    }
  }
</style>
